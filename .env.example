NODE_ENV=development
PORT=3005
API_PREFIX=api/v1
APP_URL=http://localhost:3005
CORS_ORIGINS=http://localhost:5173,http://localhost:3005

# keep Neon credentials secure: do not expose them to client-side code

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_SSL=true
DATABASE_SYNCHRONIZE=false
TYPEORM_LOGGING=false

JWT_ACCESS_SECRET=change-me-access-secret12345@@@
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret12345@@@
JWT_REFRESH_EXPIRES_IN=30d

DEFAULT_CURRENCY_CODE=VND
DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
SYNC_MAX_BATCH_SIZE=100
REQUEST_ID_HEADER=x-request-id
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# AI Processing provider
AI_PROVIDER=GetNexAI
AI_PROVIDER_BASE_URL=https://getnexai.net/api/v1
AI_PROVIDER_RESPONSES_PATH=/responses
AI_PROVIDER_MODEL=gpt-5.5
AI_PROVIDER_API_KEY=
AI_PROVIDER_TIMEOUT_SECONDS=30
AI_PROVIDER_REASONING_EFFORT=low
AI_PROVIDER_VERBOSITY=low

# Supabase Storage for AI Processing
SUPABASE_STORAGE_BASE_URL=https://jxslxbxhyclfkfrjlnic.supabase.co
SUPABASE_STORAGE_PUBLIC_URL=https://jxslxbxhyclfkfrjlnic.supabase.co/storage/v1/object/public/Image
SUPABASE_STORAGE_API_KEY=
SUPABASE_STORAGE_BUCKET_NAME=Image
SUPABASE_STORAGE_FOLDER=ai-processing

# .NET microservice-compatible aliases
FLOWFI_AI__AiProvider__Provider=GetNexAI
FLOWFI_AI__AiProvider__BaseUrl=https://getnexai.net/api/v1
FLOWFI_AI__AiProvider__ResponsesPath=/responses
FLOWFI_AI__AiProvider__Model=gpt-5.5
FLOWFI_AI__AiProvider__ApiKey=
FLOWFI_AI__AiProvider__TimeoutSeconds=30
FLOWFI_AI__AiProvider__ReasoningEffort=low
FLOWFI_AI__AiProvider__Verbosity=low
FLOWFI_AI__SupabaseStorage__BaseUrl=
FLOWFI_AI__SupabaseStorage__ApiKey=
FLOWFI_AI__SupabaseStorage__BucketName=Image
FLOWFI_AI__SupabaseStorage__Folder=ai-processing

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FlowFi <no-reply@yourdomain.com>"
PASSWORD_RESET_OTP_TTL_MINUTES=10
